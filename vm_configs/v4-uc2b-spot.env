# VM: v4-uc2b-spot — us-central2-b — v4-32 SPOT (32 chips, 4 hosts)
# DISABLED: GLIBC 2.31 (Ubuntu 20.04) incompatible with torch_xla 2.9.0 (needs 2.34)
TPU_NAME=v4-uc2b-spot
ZONE=us-central2-b
TPU_NUM_WORKERS=4
CHIPS_PER_HOST=4
BUCKET=gs://gcp-researchcredits-blocklab-1-us-central2
ACCELERATOR_TYPE=v4-32
RUNTIME_VERSION=tpu-ubuntu2204-base
SSH_HOST=tpu-uc2b-spot
WANDB_MODE=disabled
PROCS_PER_HOST=0
LIBTPU_INIT_ARGS='--xla_tpu_use_enhanced_launch_barrier=true --xla_latency_hiding_scheduler_rerun=1 --xla_tpu_prefer_async_allgather_to_allreduce=true --xla_tpu_enable_flash_attention=false --xla_enable_async_all_gather=true --xla_enable_async_collective_permute=true'
